# Wordle & Connections LLM Bot — environment configuration
# Copy to .env and fill in DISCORD_WEBHOOK_URL. .env is git-ignored; never commit secrets.

# Discord webhook URL (/api/webhooks/{id}/{token}). REQUIRED, secret. Never logged.
DISCORD_WEBHOOK_URL=

# Ollama base URL (compose service DNS, NOT localhost).
OLLAMA_HOST=http://ollama:11434
# Model tag. CPU fallbacks: gemma4:e4b, gemma3:4b. GPU: gemma4:31b.
OLLAMA_MODEL=gemma4:12b
# Context window for the model call; must hold prompt + state + schema.
OLLAMA_NUM_CTX=8192
# Sampling temperature (0 => most deterministic).
OLLAMA_TEMPERATURE=0
# Fixed seed for near-reproducible runs.
OLLAMA_SEED=42
# Max tokens generated per turn (caps reasoning length).
OLLAMA_NUM_PREDICT=768
# Pull OLLAMA_MODEL at startup if missing.
OLLAMA_AUTO_PULL=true

# Which games to play each cycle.
GAME_TYPES=wordle,connections
# Daily run time (cron, in SCHEDULE_TZ).
SCHEDULE_CRON=15 0 * * *
# Timezone for the schedule and "today" computation.
SCHEDULE_TZ=America/New_York
# Enable POST /play.
MANUAL_TRIGGER_ENABLED=true
# Corrective re-prompt cap (backstop against infinite loops).
MAX_INVALID_RETRIES=10
# Enforce hard-mode constraints on the model's guesses.
WORDLE_HARD_MODE=false

# Browser UA sent to NYT (helps with Connections' DataDome shield).
NYT_USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)
# NYT request timeout (seconds).
NYT_TIMEOUT_SECONDS=10
# NYT fetch retry count (with backoff).
NYT_MAX_RETRIES=3
# If true, post a "couldn't fetch today's puzzle" notice.
POST_ON_FETCH_FAILURE=false

# SQLite file path (on the mounted volume).
DB_PATH=/data/games.db
# Logging verbosity.
LOG_LEVEL=INFO
